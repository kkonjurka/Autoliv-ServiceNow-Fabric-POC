          "m": 4,
          "efConstruction": 400,
          "efSearch": 500
        }
      }
    ],
    "profiles": [
      {
        "name": "incident-vector-profile",
        "algorithm": "incident-hnsw",
        "vectorizer": "incident-azure-openai-vectorizer"
      }
    ],
    "vectorizers": [
      {
        "name": "incident-azure-openai-vectorizer",
        "kind": "azureOpenAI",
        "azureOpenAIParameters": {
          "resourceUri": "${AZURE_OPENAI_ENDPOINT}",
          "deploymentId": "text-embedding-ada-002",
          "modelName": "text-embedding-ada-002"
        }
      }
    ]
  },
  "semantic": {
    "configurations": [
      {
        "name": "incident-semantic-config",
        "prioritizedFields": {
          "titleField": {
            "fieldName": "incident_summary"
          },
          "prioritizedContentFields": [
            { "fieldName": "resolution_notes" },
            { "fieldName": "work_notes" },
            { "fieldName": "description" }
          ],
          "prioritizedKeywordsFields": [
            { "fieldName": "category" },
            { "fieldName": "subcategory" },
            { "fieldName": "assigned_group" }
          ]
        }
      }
    ]
  },
  "scoringProfiles": [
    {
      "name": "incident-relevance-boost",
      "text": {
        "weights": {
          "incident_summary": 2.0,
          "resolution_notes": 1.5,
          "work_notes": 1.0,
          "description": 1.0
        }
      },
      "functions": [
        {
          "fieldName": "updated_date",
          "boost": 1.2,
          "type": "freshness",
          "freshness": {
            "boostingDuration": "P90D"
          }
        }
      ],
      "functionAggregation": "sum"
    }
  ]
