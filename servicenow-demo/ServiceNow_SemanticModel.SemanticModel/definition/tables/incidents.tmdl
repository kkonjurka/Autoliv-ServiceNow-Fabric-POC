    column resolution_notes_clean
        dataType: string
        lineageTag: 2d1a3c5c-8717-4bc4-9336-54bca2267b8f
        sourceLineageTag: resolution_notes_clean
        sourceColumn: resolution_notes_clean
        summarizeBy: none

    measure 'Ticket Volume' = COUNTROWS ( incidents )
        formatString: 0
        description: Total incident count in the current filter context.

    measure 'Open Ticket Count' =
        CALCULATE (
            COUNTROWS ( incidents ),
            incidents[state] IN { "New", "In Progress", "On Hold" }
        )
        formatString: 0
        description: Count of incidents currently in an open workflow state.

    measure 'Backlog by Priority' = [Open Ticket Count]
        formatString: 0
        description: Open backlog measure intended for use with the incident priority column.

    measure 'Average Resolution Time' =
        AVERAGEX (
            FILTER ( incidents, NOT ISBLANK ( incidents[resolved_at] ) ),
            DATEDIFF ( incidents[opened_at], incidents[resolved_at], HOUR )
        )
        formatString: 0.0
        description: Average resolution time in hours for resolved incidents.

    measure 'SLA Breach Count' =
        CALCULATE (
            COUNTROWS ( slas ),
            slas[breached] = TRUE
        )
        formatString: 0
        description: Count of breached SLA records linked to the visible incidents.

    measure 'Aging Open Tickets' =
        CALCULATE (
            COUNTROWS ( incidents ),
            incidents[state] IN { "New", "In Progress", "On Hold" },
            FILTER ( incidents, DATEDIFF ( incidents[opened_at], TODAY (), DAY ) > 7 )
        )
        formatString: 0
        description: Open incidents older than seven days.

    partition incidents = entity
        mode: directLake
        source
            entityName: incidents
            schemaName: dbo
            expressionSource: DatabaseQuery
