# Copy this file to .env and fill in values locally.
# Do not commit .env. It is ignored by .gitignore.
#
# Quote any value that contains spaces so the Bash deployment script can source it safely.
#
# CI/CD secrets:
# - AZURE_SUBSCRIPTION_ID
# - AZURE_TENANT_ID
# - AZURE_CLIENT_ID
# - AZURE_CLIENT_SECRET (only when not using OIDC/federated credentials)
# - API_AUTH_HEADER_VALUE (optional future runtime secret)

# Azure authentication
# Recommended local path: use `az login` and set AZURE_SUBSCRIPTION_ID only.
# Recommended automation path: use GitHub Actions secrets or Azure DevOps variable groups.
AZURE_SUBSCRIPTION_ID=
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# Azure deployment targets
AZURE_LOCATION=eastus
AZURE_RESOURCE_GROUP=rg-autoliv-servicenow-fabric-poc
AZURE_CONTAINER_REGISTRY_NAME=
AZURE_CONTAINER_REGISTRY_SKU=Basic
AZURE_CONTAINER_APPS_ENV_NAME=acae-autoliv-servicenow-poc
AZURE_CONTAINER_APP_NAME=aca-servicenow-mock-api

# Container image settings
CONTAINER_IMAGE_NAME=servicenow-mock-api
CONTAINER_IMAGE_TAG=latest
CONTAINER_PORT=8000

# Azure Container Apps sizing
ACA_CPU=0.5
ACA_MEMORY=1.0Gi
ACA_MIN_REPLICAS=1
ACA_MAX_REPLICAS=1

# Runtime environment variables passed to the container app
SERVICENOW_API_HOST=0.0.0.0
SERVICENOW_API_PORT=8000
SERVICENOW_DB_PATH=/app/data/servicenow_mock.sqlite
SERVICENOW_RESEED_ON_STARTUP=true
MOCK_URL_BASE=

# Optional future demo authentication header.
# The current mock API does not enforce this yet, so leave it blank unless the API adds auth.
API_AUTH_HEADER_NAME=x-demo-api-key
API_AUTH_HEADER_VALUE=

# Fabric deployment and ingestion targets
FABRIC_WORKSPACE_ID=
FABRIC_WORKSPACE_NAME=
FABRIC_LAKEHOUSE_ID=
FABRIC_LAKEHOUSE_NAME=lh_servicenow_poc
FABRIC_WAREHOUSE_ID=
FABRIC_SEMANTIC_MODEL_NAME="ServiceNow Support Semantic Model"
FABRIC_DATA_AGENT_NAME="ServiceNow Support Data Agent"

# Foundry orchestration targets
FOUNDRY_PROJECT_NAME=autoliv-servicenow-poc
FOUNDRY_ORCHESTRATOR_AGENT_NAME=servicenow-support-orchestrator

# Filled in after Azure Container Apps deployment
ACR_LOGIN_SERVER=
MOCK_SERVICENOW_API_BASE_URL=
MOCK_SERVICENOW_API_HEALTH_URL=
